<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Painel Digital CMR</title>
  <style>
    :root { --verde: #006837; --amarelo: #fff200; --preto: #000; --branco: #fff; }
    body, html { margin: 0; padding: 0; height: 100%; width: 100%; overflow: hidden; background: var(--preto); font-family: 'Segoe UI', sans-serif; }
    
    .main-layout { display: flex; width: 100vw; height: calc(100vh - 65px); }
    .midia-area { flex: 3; position: relative; border: 6px solid var(--amarelo); box-sizing: border-box; background: #050505; display: flex; justify-content: center; align-items: center; overflow: hidden; }

    .fade-in { animation: fadeInEffect 1.2s ease-in-out; }
    @keyframes fadeInEffect {
      from { opacity: 0; transform: scale(1.03); }
      to { opacity: 1; transform: scale(1); }
    }

    #display-conteudo { width: 100%; height: 100%; display: flex; justify-content: center; align-items: center; }
    img, iframe { width: 100%; height: 100%; object-fit: contain; border: none; }

    #legenda-sobreposta { position: absolute; bottom: 0; left: 0; width: 100%; background: rgba(0, 104, 55, 0.9); color: var(--amarelo); padding: 15px 0; text-align: center; font-size: 2.2rem; font-weight: 900; text-transform: uppercase; z-index: 10; display: none; }
    .sidebar { flex: 1; background: var(--verde); display: flex; flex-direction: column; align-items: center; padding: 20px; border-left: 2px solid var(--amarelo); color: var(--branco); box-sizing: border-box; }
    .logo { width: 85%; margin-bottom: 30px; }
    #relogio { font-size: 4.5rem; font-weight: 900; color: var(--amarelo); margin: 0; }
    #data { font-size: 1.2rem; text-transform: uppercase; letter-spacing: 2px; text-align: center; }
    .frase-box { width: 100%; text-align: center; border-top: 1px solid rgba(255,255,255,0.2); padding-top: 25px; margin-top: 20px; }
    #texto-frase { font-size: 1.6rem; font-style: italic; font-weight: 700; line-height: 1.3; }

    .card-aviso-tv { background: #00334d; border: 5px solid var(--amarelo); border-radius: 15px; padding: 40px; max-width: 85%; text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
    .texto-aviso-tv { font-size: 3.2rem; font-weight: bold; color: white; line-height: 1.4; }

    .footer { position: fixed; bottom: 0; width: 100%; background: var(--preto); height: 65px; display: flex; align-items: center; border-top: 4px solid var(--amarelo); z-index: 100; }
    .marquee { white-space: nowrap; font-size: 2rem; font-weight: bold; color: var(--amarelo); animation: scroll 25s linear infinite; padding-left: 100vw; }
    @keyframes scroll { 0% { transform: translateX(0); } 100% { transform: translateX(-100%); } }
    .sep { margin: 0 40px; color: var(--branco); }
  </style>
</head>
<body>
  <div class="main-layout">
    <div class="midia-area">
      <div id="display-conteudo">Carregando painel...</div>
      <div id="legenda-sobreposta"></div>
    </div>
    <div class="sidebar">
      <img src="https://i.postimg.cc/85zXp9mX/logo-cmr.png" class="logo">
      <div id="relogio">00:00:00</div>
      <div id="data">...</div>
      <div class="frase-box">
        <span style="color: var(--amarelo); font-size: 0.8rem; font-weight: bold; letter-spacing: 2px;">FRASE DO DIA</span>
        <div id="texto-frase">Carregando...</div>
      </div>
    </div>
  </div>
  <div class="footer"><div class="marquee" id="letreiro">Carregando letreiro...</div></div>

  <script>
    // ⚠️ SUBSTITUA COM A SUA URL DO GOOGLE APPS SCRIPT GERADA NO PASSO 1
    const URL_API = "COLE_AQUI_A_SUA_URL_DO_APP_DA_WEB";

    let midias = [], frases = [], idxM = 0, idxF = 0;
    let timerMidia = null, timerFrase = null;

    function atualizarRelogio() {
      const agora = new Date();
      document.getElementById('relogio').innerText = agora.toLocaleTimeString('pt-BR');
      const opt = { weekday: 'long', day: 'numeric', month: 'short' };
      document.getElementById('data').innerText = agora.toLocaleDateString('pt-BR', opt).toUpperCase();
    }
    setInterval(atualizarRelogio, 1000);

    // Nova função de carregamento via API externa
    function carregar() {
      fetch(URL_API)
        .then(response => response.json())
        .then(res => {
          midias = res.midias; 
          frases = res.frases;
          
          if (res.letreiros && res.letreiros.length > 0) {
            document.getElementById('letreiro').innerHTML = res.letreiros.join(' <span class="sep"> ★ </span> ') + ' <span class="sep"> ★ </span> ';
          }
          
          if(!timerMidia && midias.length > 0) girarM();
          if(!timerFrase && frases.length > 0) girarF();
        })
        .catch(err => console.error("Erro ao buscar dados da planilha: ", err));
    }

    function extrairIdDrive(url) {
      if (!url) return "";
      const regExp = /(?:id=|\/d\/|src=)([\w-]+)/;
      const match = url.match(regExp);
      return (match && match[1]) ? match[1] : "";
    }

    function girarM() {
      if (timerMidia) clearTimeout(timerMidia);
      if (!midias.length) return;
      
      const item = midias[idxM];
      const box = document.getElementById('display-conteudo');
      const legenda = document.getElementById('legenda-sobreposta');

      box.classList.remove('fade-in');
      void box.offsetWidth; 
      box.classList.add('fade-in');

      if (item.tipo !== "Texto" && item.titulo && item.titulo.trim() !== "") {
        legenda.innerText = item.titulo;
        legenda.style.display = "block";
      } else {
        legenda.style.display = "none";
      }

      let idDrive = extrairIdDrive(item.link);

      if (item.tipo === "Imagem") {
        if(idDrive) {
          box.innerHTML = `<img src="https://drive.google.com/uc?export=view&id=${idDrive}">`;
        } else {
          box.innerHTML = `<div style="color:red; font-size:1.5rem;">Link de Imagem Inválido</div>`;
        }
      } else if (item.tipo === "Vídeo") {
        if(idDrive) {
          box.innerHTML = `<iframe src="https://drive.google.com/file/d/${idDrive}/preview?autoplay=1&mute=1"></iframe>`;
        } else {
          let linkAdaptado = item.link.includes('youtube.com') ? item.link.replace('watch?v=', 'embed/') : item.link;
          box.innerHTML = `<iframe src="${linkAdaptado}"></iframe>`;
        }
      } else {
        box.innerHTML = `
          <div class="card-aviso-tv">
            <div style="font-size: 1.5rem; color: var(--amarelo); text-transform: uppercase; margin-bottom: 15px; border-bottom: 1px solid var(--amarelo); padding-bottom: 5px;">${item.titulo || 'Aviso Interno'}</div>
            <div class="texto-aviso-tv">${item.link}</div>
          </div>
        `;
      }

      idxM = (idxM + 1) % midias.length;
      let tempoMili = (parseFloat(item.tempo) || 15) * 1000;
      timerMidia = setTimeout(girarM, tempoMili);
    }

    function girarF() {
      if (timerFrase) clearTimeout(timerFrase);
      if (!frases.length) return;

      document.getElementById('texto-frase').innerText = `"${frases[idxF]}"`;
      idxF = (idxF + 1) % frases.length;
      timerFrase = setTimeout(girarF, 20000);
    }

    setInterval(carregar, 180000);
    window.onload = carregar;
  </script>
</body>
</html>
